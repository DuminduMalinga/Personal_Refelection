<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card_background"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="#CCCCCC"
        android:layout_margin="4dp"/>

    <!-- Sheet header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp">

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_stat_card_blue"
            android:layout_marginEnd="12dp">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_edit_blue"
                android:scaleType="fitCenter"
                android:contentDescription="@string/lbl_edit_profile"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW REFLECTION"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="What's on your mind? ✨"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="1dp"/>
        </LinearLayout>

        <!-- Close button -->
        <FrameLayout
            android:id="@+id/btnCloseSheet"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_chip_inactive_pill"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✕"
                android:textSize="13sp"
                android:textColor="#6C63FF"
                android:textStyle="bold"
                android:clickable="false"
                android:focusable="false"/>
        </FrameLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginBottom="16dp"/>

    <!-- Reflection text input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSheetReflectionContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp"
        app:boxStrokeColor="@color/primary_green"
        app:hintTextColor="@color/primary_green"
        android:hint="What did you reflect on today?">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSheetReflectionContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:inputType="textCapSentences|textMultiLine"
            android:minLines="4"
            android:maxLines="8"
            android:gravity="top"
            android:fontFamily="sans-serif"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Link to Goal label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Link to Goal (optional)"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif-medium"
        android:layout_marginStart="20dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="6dp"/>

    <!-- Goal spinner -->
    <Spinner
        android:id="@+id/sheetSpinnerGoal"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_input_rounded"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"/>

    <!-- Mood row -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="How are you feeling?"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif-medium"
        android:layout_marginStart="20dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView android:id="@+id/moodHappy"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="😊"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/bg_chip_inactive_pill"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="6dp"/>

        <TextView android:id="@+id/moodNeutral"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="😐"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/bg_chip_inactive_pill"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="6dp"/>

        <TextView android:id="@+id/moodSad"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="😔"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/bg_chip_inactive_pill"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="6dp"/>

        <TextView android:id="@+id/moodMotivated"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🔥"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/bg_chip_inactive_pill"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Save button -->
    <Button
        android:id="@+id/btnSheetSaveReflection"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="20dp"
        android:text="💡  Save Reflection"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_save_goal_btn"
        android:stateListAnimator="@null"
        android:elevation="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"/>

</LinearLayout>

