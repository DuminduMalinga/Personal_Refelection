<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/profileRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="96dp">

            <!-- ══════════════════ HERO HEADER ══════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_profile_hero"
                android:paddingTop="52dp"
                android:paddingBottom="32dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <!-- ── Top bar: label pill + settings icon ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <!-- Glassy label pill -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_label_pill"
                        android:gravity="center_vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✦"
                            android:textColor="#CCFFFFFF"
                            android:textSize="9sp"
                            android:includeFontPadding="false"
                            android:layout_marginEnd="5dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MY PROFILE"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:letterSpacing="0.16"
                            android:textAllCaps="true"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <!-- Pulse dots -->
                    <View android:layout_width="6dp" android:layout_height="6dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_status_dot"/>
                    <View android:layout_width="4dp" android:layout_height="4dp"
                        android:layout_marginStart="5dp" android:alpha="0.5"
                        android:background="@drawable/bg_status_dot"/>

                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1"/>

                    <!-- Edit profile icon top-right -->
                    <FrameLayout
                        android:id="@+id/btnEditAvatar"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_edit_badge_modern"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="4dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_edit"
                            android:contentDescription="@string/content_desc_edit_profile"
                            android:scaleType="fitCenter" />
                    </FrameLayout>
                </LinearLayout>

                <!-- ── Avatar centred with glow ring ── -->
                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center_horizontal">

                    <!-- Glow ring -->
                    <View
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:background="@drawable/bg_profile_avatar_ring"/>

                    <!-- Photo -->
                    <ImageView
                        android:id="@+id/ivProfileImage"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_avatar_circle_white"
                        android:src="@drawable/ic_person"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/content_desc_profile_icon" />

                    <!-- Green status dot -->
                    <View
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/bg_status_dot"
                        android:elevation="6dp"/>
                </FrameLayout>

                <!-- ── Name ── -->
                <TextView
                    android:id="@+id/tvFullName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:text="@string/hint_full_name"
                    android:textSize="24sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:shadowColor="#44000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4"/>

                <!-- ── Email in glassy pill ── -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_label_pill"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">
                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hint_email"
                        android:textColor="#EEE0DFFF"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif"/>
                </LinearLayout>

                <!-- ── Decorative teal accent line ── -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">
                    <View android:layout_width="40dp" android:layout_height="3dp"
                        android:background="@drawable/bg_status_dot" android:alpha="0.5"/>
                    <View android:layout_width="8dp" android:layout_height="8dp"
                        android:background="@drawable/bg_status_dot"
                        android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>
                    <View android:layout_width="40dp" android:layout_height="3dp"
                        android:background="@drawable/bg_status_dot" android:alpha="0.5"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:text="@string/hint_username" />

            </LinearLayout>

            <!-- ══════════════════ STATS SECTION ══════════════════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="24dp"
                android:paddingEnd="20dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:text="@string/lbl_my_journey"
                    android:textAllCaps="true"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <!-- 3 Stat Cards Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="149dp"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Active Goals -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/card_background"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="139dp"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_stat_card_blue">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/content_desc_stat_goals"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/ic_target" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvStatActiveGoals"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="0"
                                android:textColor="@color/stat_blue"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sans-serif"
                                android:gravity="center"
                                android:text="@string/lbl_active_goals"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Achieved Goals -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/card_background"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="139dp"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_stat_card_green">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/content_desc_stat_achieved"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/ic_check_circle" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvStatAchievedGoals"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="0"
                                android:textColor="@color/stat_green"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sans-serif"
                                android:gravity="center"
                                android:text="@string/lbl_achieved_goals"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Total Reflections -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/card_background"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="139dp"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_stat_card_orange">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/content_desc_stat_reflections"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/ic_reflection" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvStatTotalReflections"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="0"
                                android:textColor="@color/stat_orange"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sans-serif"
                                android:gravity="center"
                                android:text="@string/lbl_total_reflections"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </LinearLayout>

            <!-- ══════════════════ ACCOUNT SETTINGS LIST ══════════════════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="24dp"
                android:paddingEnd="20dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:text="@string/lbl_account_settings"
                    android:textAllCaps="true"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <!-- ── Row: Edit Profile ── -->
                        <LinearLayout
                            android:id="@+id/rowEditProfile"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_settings_icon">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/lbl_edit_profile"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/ic_edit_blue" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:fontFamily="sans-serif"
                                android:text="@string/lbl_edit_profile"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/content_desc_arrow"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_arrow_right" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="76dp"
                            android:background="@color/divider" />


                        <!-- ── Row: Notification Settings ── -->
                        <LinearLayout
                            android:id="@+id/rowNotificationSettings"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_settings_icon">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/lbl_notification_settings"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/ic_bell" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:fontFamily="sans-serif"
                                android:text="@string/lbl_notification_settings"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/content_desc_arrow"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_arrow_right" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="76dp"
                            android:background="@color/divider" />

                        <!-- ── Row: App Theme ── -->
                        <LinearLayout
                            android:id="@+id/rowAppTheme"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_settings_icon">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="App Theme"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/ic_theme" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="16dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif"
                                    android:text="App Theme"
                                    android:textColor="@color/text_primary"
                                    android:textSize="15sp" />

                                <TextView
                                    android:id="@+id/tvCurrentTheme"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="sans-serif"
                                    android:text="Follow System"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/content_desc_arrow"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_arrow_right" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="76dp"
                            android:background="@color/divider" />

                        <!-- ── Row: Privacy Policy ── -->
                        <LinearLayout
                            android:id="@+id/rowPrivacyPolicy"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_settings_icon">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/lbl_privacy_policy"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/ic_file_text" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:fontFamily="sans-serif"
                                android:text="@string/lbl_privacy_policy"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/content_desc_arrow"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_arrow_right" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="76dp"
                            android:background="@color/divider" />

                        <!-- ── Row: About App ── -->
                        <LinearLayout
                            android:id="@+id/rowAboutApp"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_settings_icon">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/lbl_about_app"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/ic_info" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:fontFamily="sans-serif"
                                android:text="@string/lbl_about_app"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/content_desc_arrow"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_arrow_right" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ══════════════════ LOGOUT SECTION ══════════════════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="24dp"
                android:paddingEnd="20dp"
                android:paddingBottom="8dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">

                    <!-- Logout Row -->
                    <LinearLayout
                        android:id="@+id/rowLogout"
                        android:layout_width="match_parent"
                        android:layout_height="61dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_logout_icon">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/btn_logout"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_logout" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/btn_logout"
                            android:textColor="@color/profile_logout_red"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/content_desc_arrow"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_arrow_right" />
                    </LinearLayout>

                </androidx.cardview.widget.CardView>


            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ══════════════════ BOTTOM NAVIGATION ══════════════════ -->
    <include
        android:id="@+id/bottomNavInclude"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
