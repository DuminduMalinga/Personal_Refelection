<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/topNavInclude"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:paddingStart="22dp"
    android:paddingEnd="22dp"
    android:paddingTop="8dp"
    android:paddingBottom="18dp">

    <!-- ══ ROW 1: Label pill  ·  ·  spacer  ·  Avatar ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- ✦ Glassy gradient screen-label pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_label_pill"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="12dp">

            <!-- Tiny spark -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp"
                android:includeFontPadding="false"
                android:layout_marginEnd="5dp"/>

            <TextView
                android:id="@+id/topNavScreenLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MY GOALS"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:letterSpacing="0.16"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Two decorative pulse dots -->
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_status_dot" />
        <View
            android:layout_width="4dp"
            android:layout_height="4dp"
            android:layout_marginStart="5dp"
            android:alpha="0.5"
            android:background="@drawable/bg_status_dot" />

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <!-- ── Avatar: gradient glow ring + image + status dot ── -->
        <FrameLayout
            android:id="@+id/topNavProfileIcon"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:clickable="true"
            android:focusable="true"
            android:elevation="4dp">

            <!-- Gradient glow ring -->
            <View
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_avatar_ring_modern" />

            <!-- Photo / default icon -->
            <ImageView
                android:id="@+id/topNavProfileImage"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:clipToOutline="true"
                android:background="@drawable/bg_avatar_circle_white"
                android:src="@drawable/ic_profile"
                android:contentDescription="@string/content_desc_profile_icon" />

            <!-- 🟢 Online status dot -->
            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="0dp"
                android:layout_marginBottom="0dp"
                android:background="@drawable/bg_status_dot"
                android:elevation="6dp" />

        </FrameLayout>
    </LinearLayout>

    <!-- ══ ROW 2: Big bold greeting ══ -->
    <TextView
        android:id="@+id/topNavGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Good Morning 👋"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="-0.01"
        android:shadowColor="#44000000"
        android:shadowDx="0"
        android:shadowDy="1"
        android:shadowRadius="4" />

    <!-- ══ ROW 3: Tagline with coloured accent bar + sparkle ══ -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">

        <!-- Green accent pill bar -->
        <View
            android:layout_width="4dp"
            android:layout_height="16dp"
            android:background="@drawable/bg_status_dot"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/topNavTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reflect. Improve. Achieve. ✨"
            android:textColor="#CCE8DEFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.01" />
    </LinearLayout>

</LinearLayout>
