<?xml version="1.0" encoding="utf-8"?>
<!-- Shared custom bottom navigation bar with 3D FAB center button -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="0dp"
    app:cardElevation="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="72dp">

        <!-- LEFT: Dashboard + Goals -->
        <LinearLayout
            android:id="@+id/navLeft"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@+id/fabAdd"
            android:orientation="horizontal">

            <!-- Dashboard -->
            <LinearLayout
                android:id="@+id/navDashboard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:paddingTop="10dp"
                android:paddingBottom="8dp">
                <ImageView
                    android:id="@+id/navIconDashboard"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home"
                    android:contentDescription="@string/nav_dashboard" />
                <TextView
                    android:id="@+id/navTextDashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_dashboard"
                    android:textSize="10sp"
                    android:textColor="@color/text_hint"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <!-- Goals -->
            <LinearLayout
                android:id="@+id/navGoals"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:paddingTop="10dp"
                android:paddingBottom="8dp">
                <ImageView
                    android:id="@+id/navIconGoals"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_target"
                    android:contentDescription="@string/nav_goals" />
                <TextView
                    android:id="@+id/navTextGoals"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_goals"
                    android:textSize="10sp"
                    android:textColor="@color/text_hint"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="3dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- RIGHT: Achieved + Profile -->
        <LinearLayout
            android:id="@+id/navRight"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:layout_toEndOf="@+id/fabAdd"
            android:orientation="horizontal">

            <!-- Achieved -->
            <LinearLayout
                android:id="@+id/navAchieved"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:paddingTop="10dp"
                android:paddingBottom="8dp">
                <ImageView
                    android:id="@+id/navIconAchieved"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check_circle"
                    android:contentDescription="@string/nav_achieved" />
                <TextView
                    android:id="@+id/navTextAchieved"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_achieved"
                    android:textSize="10sp"
                    android:textColor="@color/text_hint"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <!-- Profile -->
            <LinearLayout
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:paddingTop="10dp"
                android:paddingBottom="8dp">
                <ImageView
                    android:id="@+id/navIconProfile"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_profile"
                    android:contentDescription="@string/nav_profile" />
                <TextView
                    android:id="@+id/navTextProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_profile"
                    android:textSize="10sp"
                    android:textColor="@color/text_hint"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="3dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- CENTER: 3D FAB Add Button (raised) -->
        <FrameLayout
            android:id="@+id/fabAdd"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/selector_fab_3d"
            android:elevation="16dp"
            android:translationZ="8dp"
            android:stateListAnimator="@null">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_add_3d_plus"
                android:contentDescription="@string/nav_add" />
        </FrameLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>

