<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ══════════════════════════════════════════════════════════ -->
    <!--  SCROLLABLE CONTENT                                        -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/scrollView2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="170dp">

            <!-- ════════ HERO HEADER ════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashboard_header"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="52dp"
                android:paddingBottom="28dp">

                <!-- Top row: greeting + avatar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/greeting_morning"
                            android:textColor="#AACCE0FF"
                            android:textSize="13sp"
                            android:letterSpacing="0.06"
                            android:textAllCaps="true"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/greeting_afternoon"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/tvTagline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_tagline"
                            android:textColor="#99D0CFFF"
                            android:textSize="13sp"
                            android:layout_marginTop="5dp" />
                    </LinearLayout>

                    <!-- Avatar button -->
                    <FrameLayout
                        android:id="@+id/ivProfileIcon"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_avatar_ring"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_avatar_circle_white">

                            <ImageView
                                android:id="@+id/ivDashboardProfileImage"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:layout_gravity="center"
                                android:scaleType="centerCrop"
                                android:clipToOutline="true"
                                android:contentDescription="@string/content_desc_profile_icon"
                                android:src="@drawable/ic_profile" />
                        </FrameLayout>
                    </FrameLayout>
                </LinearLayout>

                <!-- Motivational quote strip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_quote_strip"
                    android:padding="12dp"
                    android:layout_marginTop="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✦"
                        android:textColor="#FFD700"
                        android:textSize="14sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/gs_quote_short"
                        android:textColor="#EEEEFF"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif"
                        android:lineSpacingMultiplier="1.4"
                        android:ellipsize="end"
                        android:maxLines="2" />
                </LinearLayout>
            </LinearLayout>

            <!-- ════════ STAT CARDS ════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="20dp"
                android:paddingBottom="4dp">

                <!-- Active Goals Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardActiveGoals"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Colored icon badge -->
                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_stat_badge_blue">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/content_desc_target_icon"
                                android:src="@drawable/ic_target" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvActiveGoalsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/lbl_active_goals"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:letterSpacing="0.02" />

                        <!-- Bottom accent bar -->
                        <View
                            android:layout_width="28dp"
                            android:layout_height="3dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_accent_bar_blue" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Achieved Goals Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAchievedGoals"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_stat_badge_green">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/content_desc_check_icon"
                                android:src="@drawable/ic_check_circle" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvAchievedGoalsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/lbl_achieved_goals"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:letterSpacing="0.02" />

                        <View
                            android:layout_width="28dp"
                            android:layout_height="3dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_accent_bar_green" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Total Reflections Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTotalReflections"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_stat_badge_orange">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/content_desc_reflection_icon"
                                android:src="@drawable/ic_reflection" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvTotalReflectionsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/lbl_total_reflections"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:letterSpacing="0.02" />

                        <View
                            android:layout_width="28dp"
                            android:layout_height="3dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_accent_bar_orange" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ════════ SECTION HEADER: Recent Reflections ════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="26dp"
                android:paddingBottom="12dp">

                <!-- Left accent pip -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="22dp"
                    android:background="@drawable/bg_reflection_accent"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/lbl_recent_reflections"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <!-- + Add Reflection quick button -->
                <LinearLayout
                    android:id="@+id/btnDashAddReflection"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_chip_active_pill"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Add"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="false"
                        android:focusable="false"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSeeAllReflections"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lbl_see_all"
                    android:textColor="@color/primary_green"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Reflections container -->
            <LinearLayout
                android:id="@+id/recentReflectionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:id="@+id/tvNoReflections"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="32dp"
                    android:text="@string/lbl_no_reflections"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!--  FIXED BOTTOM BAR                                          -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@android:color/transparent">

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="8dp"
            android:background="@color/background">

            <Button
                android:id="@+id/btnViewGoals"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_green"
                android:elevation="0dp"
                android:fontFamily="sans-serif-medium"
                android:stateListAnimator="@null"
                android:text="@string/btn_view_goals"
                android:textColor="@color/text_light"
                android:textSize="14sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_target_small"
                android:drawablePadding="6dp" />

            <Button
                android:id="@+id/btnViewAchieved"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_outlined"
                android:elevation="0dp"
                android:fontFamily="sans-serif-medium"
                android:stateListAnimator="@null"
                android:text="@string/btn_view_achieved"
                android:textColor="@color/primary_green"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── Shared Bottom Nav ── -->
        <include
            android:id="@+id/bottomNavInclude"
            layout="@layout/layout_bottom_nav" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>


