<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/goalsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ══ FIXED TOP NAV + FILTER CHIPS — one seamless header block ══ -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_goals_header"
        android:elevation="0dp"
        app:elevation="0dp"
        app:liftOnScroll="false"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar">

        <include
            android:id="@+id/topNavInclude"
            layout="@layout/layout_top_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Sub-header: MY GOALS label row -->
        <LinearLayout
            android:id="@+id/goalsHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_stat_icon_circle"
                android:layout_marginEnd="12dp">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_target"
                    android:scaleType="fitCenter"
                    app:tint="#FFFFFF"
                    android:contentDescription="@string/content_desc_target_icon" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MY GOALS"
                    android:textSize="11sp"
                    android:textColor="#BBDDE0FF"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reflect. Improve. Achieve."
                    android:textSize="13sp"
                    android:textColor="#CCFFFFFF"
                    android:layout_marginTop="1dp" />
            </LinearLayout>
        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══ SCROLLABLE CONTENT ══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="110dp">

            <!-- ── STAT CARDS ── -->
            <LinearLayout
                android:id="@+id/statsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:weightSum="2">

                <!-- Active Goals card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#6C63FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <!-- Top section: icon + count -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_stat_icon_circle">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_target"
                                    android:scaleType="fitCenter"
                                    app:tint="#FFFFFF"
                                    android:contentDescription="@string/content_desc_target_icon" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvHeaderActiveCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="36sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Bottom tab: label -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:background="#33000000"
                            android:gravity="center"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active Goals"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.04"/>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Achieved Goals card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#06D6A0">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <!-- Top section: icon + count -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_stat_icon_circle">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_check_circle"
                                    android:scaleType="fitCenter"
                                    app:tint="#FFFFFF"
                                    android:contentDescription="@string/content_desc_check_icon" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvHeaderAchievedCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="36sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="6dp"/>
                        </LinearLayout>

                        <!-- Bottom tab: label -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:background="#33000000"
                            android:gravity="center"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Achieved Goals"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.04"/>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── Goals RecyclerView ── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerGoals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"
                tools:visibility="visible"
                tools:itemCount="0" />

            <!-- ── Empty State ── -->
            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="36dp"
                android:paddingBottom="32dp"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_empty_goals"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/content_desc_target_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Goals Yet"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="18dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set your first goal and start&#10;your personal growth journey 🚀"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginTop="10dp" />

                <Button
                    android:id="@+id/btnAddGoalEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:text="@string/btn_add_goal"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:background="@drawable/bg_button_green"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:layout_marginTop="24dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ══ FAB Add Goal ══ -->
    <LinearLayout
        android:id="@+id/fabAddGoal"
        android:layout_width="wrap_content"
        android:layout_height="54dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="92dp"
        android:background="@drawable/bg_fab_goals"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_add_goal"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- ══ Bottom Nav ══ -->
    <include
        android:id="@+id/bottomNavInclude"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
