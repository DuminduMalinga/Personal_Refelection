<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/addGoalRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ══ FIXED HEADER — same style as Goals / Achieved / Reflections ══ -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_goals_header"
        android:elevation="0dp"
        app:elevation="0dp"
        app:liftOnScroll="false"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar">

        <!-- Shared top nav: greeting + avatar -->
        <include
            android:id="@+id/topNavInclude"
            layout="@layout/layout_top_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Sub-header: icon + title + subtitle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp">

            <FrameLayout
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_chip_inactive_pill"
                android:layout_marginEnd="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🎯"
                    android:textSize="20sp"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHeaderLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NEW GOAL"
                    android:textSize="10sp"
                    android:textColor="#BBDDE0FF"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvHeaderTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add a Goal"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="1dp"/>

                <TextView
                    android:id="@+id/tvHeaderSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Define your next milestone 🎯"
                    android:textSize="11sp"
                    android:textColor="#99D0CFFF"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══ SCROLLABLE CONTENT ══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════ CONTENT ══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="20dp"
                android:paddingBottom="100dp">

                <!-- ── SECTION: Goal Title ── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/card_background">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Label row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <FrameLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_stat_card_blue">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_edit_blue"
                                    android:scaleType="fitCenter"
                                    android:contentDescription="@string/lbl_edit_profile"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Goal Title"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginStart="12dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Required"
                                android:textSize="11sp"
                                android:textColor="@color/primary_green"
                                android:background="@drawable/bg_chip_inactive_pill"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"/>
                        </LinearLayout>

                        <!-- Title input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilGoalTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp"
                            app:boxStrokeColor="@color/primary_green"
                            app:hintTextColor="@color/primary_green"
                            android:hint="Enter your goal title">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etGoalTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:inputType="textCapSentences"
                                android:fontFamily="sans-serif"/>
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── SECTION: Description ── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/card_background">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <FrameLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_stat_card_blue">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_file_text"
                                    android:scaleType="fitCenter"
                                    android:contentDescription="@string/lbl_about_app"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Description"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginStart="12dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Optional"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:background="@drawable/bg_category_chip_unselected"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"/>
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilGoalDesc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusBottomEnd="14dp"
                            app:boxStrokeColor="@color/primary_green"
                            app:hintTextColor="@color/primary_green"
                            android:hint="Describe your goal…">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etGoalDescription"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:inputType="textCapSentences|textMultiLine"
                                android:minLines="3"
                                android:maxLines="5"
                                android:gravity="top"
                                android:fontFamily="sans-serif"/>
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── SECTION: Category ── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/card_background">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Label -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">

                            <FrameLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_stat_card_green">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_target"
                                    android:scaleType="fitCenter"
                                    android:contentDescription="@string/content_desc_target_icon"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Category"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginStart="12dp"/>
                        </LinearLayout>

                        <!-- Category chips row 1 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:id="@+id/chipCatHealth"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:text="💪 Health"
                                android:textSize="12sp"
                                android:textColor="#4A3FCC"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="center"
                                android:background="@drawable/bg_category_chip_unselected"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:id="@+id/chipCatStudy"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:text="📚 Study"
                                android:textSize="12sp"
                                android:textColor="#4A3FCC"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="center"
                                android:background="@drawable/bg_category_chip_unselected"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:id="@+id/chipCatCareer"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:text="💼 Career"
                                android:textSize="12sp"
                                android:textColor="#4A3FCC"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="center"
                                android:background="@drawable/bg_category_chip_unselected"
                                android:clickable="true"
                                android:focusable="true"/>
                        </LinearLayout>

                        <!-- Category chips row 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/chipCatPersonal"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:text="🌱 Personal"
                                android:textSize="12sp"
                                android:textColor="#4A3FCC"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="center"
                                android:background="@drawable/bg_category_chip_unselected"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:id="@+id/chipCatFinance"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:text="💰 Finance"
                                android:textSize="12sp"
                                android:textColor="#4A3FCC"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="center"
                                android:background="@drawable/bg_category_chip_unselected"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:id="@+id/chipCatOther"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:text="✨ Other"
                                android:textSize="12sp"
                                android:textColor="#4A3FCC"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="center"
                                android:background="@drawable/bg_category_chip_unselected"
                                android:clickable="true"
                                android:focusable="true"/>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── SECTION: Deadline + Priority side by side ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp"
                    android:baselineAligned="false"
                    android:weightSum="2">

                    <!-- Deadline — plain LinearLayout, no CardView clipping -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="7dp"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="@drawable/bg_section_card"
                        android:elevation="3dp">

                        <FrameLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_stat_card_orange"
                            android:layout_marginBottom="10dp">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_bell"
                                android:scaleType="fitCenter"
                                android:contentDescription="@string/lbl_notification_settings"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Deadline"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="10dp"/>

                        <!-- btnPickDate directly in LinearLayout — guaranteed clickable -->
                        <Button
                            android:id="@+id/btnPickDate"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:text="📅 Pick date"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            android:background="@drawable/bg_input_rounded"
                            android:stateListAnimator="@null"
                            android:elevation="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:gravity="center"
                            android:fontFamily="sans-serif"/>

                    </LinearLayout>

                    <!-- Priority — plain LinearLayout, no CardView clipping -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="7dp"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="@drawable/bg_section_card"
                        android:elevation="3dp">

                        <FrameLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_stat_card_green"
                            android:layout_marginBottom="10dp">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_flag"
                                android:scaleType="fitCenter"
                                android:contentDescription="@string/content_desc_target_icon"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Priority"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="10dp"/>

                        <Button
                            android:id="@+id/chipLow"
                            android:layout_width="match_parent"
                            android:layout_height="34dp"
                            android:text="🟢 Low"
                            android:textSize="11sp"
                            android:textColor="@color/stat_green"
                            android:background="@drawable/bg_priority_unselected"
                            android:stateListAnimator="@null"
                            android:elevation="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:layout_marginBottom="6dp"/>

                        <Button
                            android:id="@+id/chipMedium"
                            android:layout_width="match_parent"
                            android:layout_height="34dp"
                            android:text="🟡 Medium"
                            android:textSize="11sp"
                            android:textColor="@color/stat_orange"
                            android:background="@drawable/bg_priority_unselected"
                            android:stateListAnimator="@null"
                            android:elevation="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:layout_marginBottom="6dp"/>

                        <Button
                            android:id="@+id/chipHigh"
                            android:layout_width="match_parent"
                            android:layout_height="34dp"
                            android:text="🔴 High"
                            android:textSize="11sp"
                            android:textColor="@color/profile_logout_red"
                            android:background="@drawable/bg_priority_unselected"
                            android:stateListAnimator="@null"
                            android:elevation="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- ── SECTION: Progress Target ── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/card_background">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">

                            <FrameLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_stat_card_blue">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_check_circle"
                                    android:scaleType="fitCenter"
                                    android:contentDescription="@string/content_desc_check_icon"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Progress Target"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginStart="12dp"/>

                            <TextView
                                android:id="@+id/tvProgressValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="50%"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary_green"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <SeekBar
                            android:id="@+id/seekBarProgress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="100"
                            android:progress="50"
                            android:progressTint="@color/primary_green"
                            android:thumbTint="@color/primary_green_dark"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint"/>

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="100%"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint"/>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── SECTION: Reminder Toggle ── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/card_background">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="20dp">

                        <FrameLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_stat_card_orange">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_bell"
                                android:scaleType="fitCenter"
                                android:contentDescription="@string/lbl_notification_settings"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Enable Reminder"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Get notified about this goal"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchReminder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            app:trackTint="@color/primary_green_light"
                            app:thumbTint="@color/primary_green"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── SAVE BUTTON ── -->
                <Button
                    android:id="@+id/btnSaveGoal"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="🎯  Save Goal"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_save_goal_btn"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:letterSpacing="0.03"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ══ Bottom Nav ══ -->
    <include
        android:id="@+id/bottomNavInclude"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

