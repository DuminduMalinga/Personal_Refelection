<?xml version="1.0" encoding="utf-8"?>
<!-- Send Reset Link button state selector — same brand purple as login/register -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#4F46E5"
                android:endColor="#6D28D9"
                android:angle="135"
                android:type="linear" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#6C63FF"
                android:endColor="#8B5CF6"
                android:angle="135"
                android:type="linear" />
            <corners android:radius="16dp" />
            <stroke android:width="2dp" android:color="#4F46E5" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#6C63FF"
                android:endColor="#8B5CF6"
                android:angle="135"
                android:type="linear" />
            <corners android:radius="16dp" />
        </shape>
    </item>

</selector>
